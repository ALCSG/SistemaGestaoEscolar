<Window x:Class="SGE.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EduGest" Height="640" Width="1000"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent">

    <Window.Resources>
        <!-- Cores principais -->
        <SolidColorBrush x:Key="MenuBackground"   Color="#1E2235"/>
        <SolidColorBrush x:Key="MenuHover"        Color="#2A3050"/>
        <SolidColorBrush x:Key="TealAccent"       Color="#00897B"/>
        <SolidColorBrush x:Key="TealAccentDark"   Color="#00695C"/>
        <SolidColorBrush x:Key="TextLight"        Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#B0BEC5"/>

        <!-- Estilo botões da barra de título -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="46"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="12"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo botão fechar (vermelho no hover) -->
        <Style x:Key="TitleBarButtonClose" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo base dos botões do menu -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="56"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="GroupName"       Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="16,0">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="18"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           Text="{TemplateBinding Tag}"
                                           Width="28"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{TemplateBinding Foreground}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"  Value="{StaticResource MenuHover}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource TealAccent}"/>
                                <Setter Property="Foreground"                      Value="{StaticResource TextLight}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background"  Value="{StaticResource MenuHover}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource TealAccent}"/>
                                <Setter Property="Foreground"                      Value="{StaticResource TextLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Border exterior para simular sombra e bordas arredondadas -->
    <Border Background="{StaticResource MenuBackground}"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>  <!-- Barra de título -->
                <RowDefinition Height="*"/>   <!-- Conteúdo -->
            </Grid.RowDefinitions>

            <!-- ===== BARRA DE TÍTULO PERSONALIZADA ===== -->
            <Grid Grid.Row="0"
                  Background="{StaticResource TealAccentDark}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>  <!-- Alinhado com menu lateral -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Nome na barra de título -->
                <TextBlock Grid.Column="0"
                           Text="EduGest"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0"/>

                <!-- Botões minimizar, maximizar, fechar -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <Button Content="&#xE921;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMinimize_Click"
                            ToolTip="Minimizar"/>
                    <Button Content="&#xE922;"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Click="BtnMaximize_Click"
                            ToolTip="Maximizar"/>
                    <Button Content="&#xE8BB;"
                            Style="{StaticResource TitleBarButtonClose}"
                            Click="BtnClose_Click"
                            ToolTip="Fechar"/>
                </StackPanel>
            </Grid>

            <!-- ===== CONTEÚDO PRINCIPAL ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== MENU LATERAL ===== -->
                <Grid Grid.Column="0" Background="{StaticResource MenuBackground}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Logo -->
                        <RowDefinition Height="*"/>     <!-- Navegação -->
                        <RowDefinition Height="Auto"/>  <!-- Rodapé -->
                    </Grid.RowDefinitions>

                    <!-- Logo / nome da app -->
                    <Border Grid.Row="0"
                            Background="{StaticResource TealAccentDark}"
                            Padding="16,14">
                        <TextBlock Text="EduGest"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextLight}"/>
                    </Border>

                    <!-- Botões de navegação -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <RadioButton x:Name="BtnAlunos"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Alunos"
                                     Tag="&#xE77B;"
                                     Click="BtnAlunos_Click"/>

                        <RadioButton x:Name="BtnProfessores"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Professores"
                                     Tag="&#xE716;"
                                     Click="BtnProfessores_Click"/>

                        <RadioButton x:Name="BtnDisciplinas"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Disciplinas"
                                     Tag="&#xE82D;"
                                     Click="BtnDisciplinas_Click"/>

                        <RadioButton x:Name="BtnTurmas"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Turmas"
                                     Tag="&#xE731;"
                                     Click="BtnTurmas_Click"/>

                        <RadioButton x:Name="BtnAvaliacoes"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Avaliações"
                                     Tag="&#xE735;"
                                     Click="BtnAvaliacoes_Click"/>

                        <RadioButton x:Name="BtnRelatorios"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Relatórios"
                                     Tag="&#xE9D9;"
                                     Click="BtnRelatorios_Click"/>

                        <RadioButton x:Name="BtnEventos"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Eventos"
                                     Tag="&#xE787;"
                                     Click="BtnEventos_Click"/>

                        <RadioButton x:Name="BtnConfiguracoes"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Configurações"
                                     Tag="&#xE713;"
                                     Click="BtnConfiguracoes_Click"/>
                    </StackPanel>

                    <!-- Rodapé: Créditos + Data/Hora -->
                    <StackPanel Grid.Row="2">
                        <Separator Background="#2A3050" Margin="12,0"/>

                        <RadioButton x:Name="BtnCreditos"
                                     Style="{StaticResource NavButtonStyle}"
                                     Content="Créditos"
                                     Tag="&#xE90A;"
                                     Click="BtnCreditos_Click"/>

                        <Border Background="#161929" Padding="16,10">
                            <TextBlock x:Name="TxtDateTime"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11"
                                       TextAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- ===== ÁREA DE CONTEÚDO ===== -->
                <Grid Grid.Column="1" Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>  <!-- Header -->
                        <RowDefinition Height="*"/>   <!-- Frame -->
                    </Grid.RowDefinitions>

                    <!-- Header com título da página -->
                    <Border Grid.Row="0" Background="{StaticResource TealAccent}">
                        <TextBlock x:Name="TxtPageTitle"
                                   Text="HOME"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextLight}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Frame de navegação -->
                    <Frame x:Name="MainFrame"
                           Grid.Row="1"
                           NavigationUIVisibility="Hidden"
                           Background="White"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
